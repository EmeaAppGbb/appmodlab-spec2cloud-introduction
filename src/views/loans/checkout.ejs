<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css">
    <style>
        body { padding-top: 70px; }
        .navbar-brand { font-weight: bold; }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark fixed-top">
        <div class="container">
            <a class="navbar-brand" href="/">📚 OpenShelf Library</a>
            <button class="navbar-toggler" type="button" data-toggle="collapse" data-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ml-auto">
                    <li class="nav-item"><a class="nav-link" href="/">Home</a></li>
                    <li class="nav-item"><a class="nav-link" href="/books">Books</a></li>
                    <li class="nav-item"><a class="nav-link" href="/members">Members</a></li>
                    <li class="nav-item"><a class="nav-link" href="/loans">Loans</a></li>
                </ul>
            </div>
        </div>
    </nav>

    <div class="container">
        <h2 class="mb-4"><%= title %></h2>
        
        <% if (books.length === 0) { %>
            <div class="alert alert-warning">
                No books are currently available for checkout.
            </div>
            <a href="/loans" class="btn btn-secondary">Back to Loans</a>
        <% } else if (members.length === 0) { %>
            <div class="alert alert-warning">
                No active members found. Please add members before checking out books.
            </div>
            <a href="/members/new" class="btn btn-primary">Add Member</a>
            <a href="/loans" class="btn btn-secondary">Back to Loans</a>
        <% } else { %>
            <form method="POST" action="/loans/checkout">
                <div class="form-group">
                    <label for="book_id">Select Book *</label>
                    <select class="form-control" id="book_id" name="book_id" required>
                        <option value="">-- Choose a book --</option>
                        <% books.forEach(book => { %>
                            <option value="<%= book.id %>">
                                <%= book.title %> by <%= book.author %> (Available: <%= book.available_copies %>)
                            </option>
                        <% }); %>
                    </select>
                </div>

                <div class="form-group">
                    <label for="member_id">Select Member *</label>
                    <select class="form-control" id="member_id" name="member_id" required>
                        <option value="">-- Choose a member --</option>
                        <% members.forEach(member => { %>
                            <option value="<%= member.id %>">
                                <%= member.name %> (<%= member.email %>)
                            </option>
                        <% }); %>
                    </select>
                </div>

                <div class="form-group">
                    <label for="due_date">Due Date</label>
                    <input type="date" class="form-control" id="due_date" name="due_date" 
                           value="<%= new Date(Date.now() + 14*24*60*60*1000).toISOString().split('T')[0] %>">
                    <small class="form-text text-muted">Default loan period is 14 days</small>
                </div>

                <div class="form-group">
                    <button type="submit" class="btn btn-primary">Checkout Book</button>
                    <a href="/loans" class="btn btn-secondary">Cancel</a>
                </div>
            </form>
        <% } %>
    </div>

    <script src="https://code.jquery.com/jquery-3.5.1.slim.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@4.5.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
